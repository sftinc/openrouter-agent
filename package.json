{
	"name": "@sftinc/openrouter-agent",
	"version": "1.0.0",
	"description": "Agent loop wrapper for OpenRouter",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sftinc/openrouter-agent.git"
	},
	"homepage": "https://github.com/sftinc/openrouter-agent#readme",
	"bugs": {
		"url": "https://github.com/sftinc/openrouter-agent/issues"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"demo:quickstart": "tsx --env-file=.env examples/quickstart/server.ts",
		"demo:full-demo": "tsx --watch --env-file=.env examples/full-demo/server.ts",
		"demo:sub-agent": "tsx --env-file=.env examples/sub-agent/server.ts",
		"websearch": "tsx --env-file=.env examples/websearch.ts",
		"release": "commit-and-tag-version",
		"release:minor": "commit-and-tag-version --release-as minor",
		"release:patch": "commit-and-tag-version --release-as patch",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^24.12.2",
		"commit-and-tag-version": "^12.7.1",
		"tsx": "^4.7.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=20"
	}
}
